NODE_ENV=development
# current-prod-v1 -> current Polymarket production before cutover
# post-cutover-v2 -> V2 stack after migration
POLY_STACK_MODE=current-prod-v1
DRY_RUN=true
# Leave blank to derive from POLY_STACK_MODE.
USE_CLOB_V2=
LOG_LEVEL=info
BOT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
BOT_PRIVATE_KEY=
POLY_SIGNATURE_TYPE=0
POLY_FUNDER=
# These can be derived with:
# npm run clob:derive -- --write-env
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_RELAYER_API_KEY=
POLY_RELAYER_API_KEY_ADDRESS=
POLY_RELAYER_BASE_URL=https://relayer-v2.polymarket.com
POLY_CHAIN_ID=137
# Working public fallback. Live icin authenticated/private Polygon RPC tercih et.
POLY_RPC_URL=https://polygon-bor-rpc.publicnode.com
# Leave blank to derive from POLY_STACK_MODE.
# Override to https://clob-v2.polymarket.com only when explicitly testing V2 preview pre-cutover.
POLY_CLOB_BASE_URL=
POLY_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLY_DATA_API_BASE_URL=https://data-api.polymarket.com
POLY_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLY_USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
# V1/current-prod collateral token (typically USDC.e)
POLY_USDC_TOKEN=0x0000000000000000000000000000000000000000
# V2/post-cutover collateral token (pUSD)
POLY_PUSD_TOKEN=0x0000000000000000000000000000000000000000
# Optional manual override for whichever collateral token the active stack should use.
POLY_COLLATERAL_TOKEN=
CTF_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Default acik. Safe/proxy live merge icin POLY_RELAYER_* alanlarini doldur.
CTF_MERGE_ENABLED=true
CTF_AUTO_REDEEM_ENABLED=true
MERGE_MIN_SHARES=5
BOT_MODE=XUAN
ENABLE_MAKER_LAYER=false
ENTRY_TAKER_BUY_ENABLED=true
ENTRY_TAKER_PAIR_CAP=1.020
COMPLETION_CAP=0.982
MIN_EDGE_PER_SHARE=0.004
STRICT_PAIR_EFFECTIVE_CAP=0.995
NORMAL_PAIR_EFFECTIVE_CAP=1.005
COMPLETION_SOFT_CAP=1.015
COMPLETION_HARD_CAP=1.060
EMERGENCY_COMPLETION_MAX_QTY=30
MAX_NEGATIVE_EDGE_PER_MARKET_USDC=3
MAX_MARKET_EXPOSURE_SHARES=500
SOFT_IMBALANCE_RATIO=0.02
HARD_IMBALANCE_RATIO=0.05
LOT_LADDER=20,40,60,80,100
LIVE_SMALL_LOTS=20,40
DEFAULT_LOT=40
MAX_MARKET_SHARES_PER_SIDE=500
MAX_ONE_SIDED_EXPOSURE_SHARES=150
MAX_IMBALANCE_FRAC=0.02
FORCE_REBALANCE_IMBALANCE_FRAC=0.05
REBALANCE_LEADING_FRACTION=0.25
REBALANCE_MAX_LAGGING_MULTIPLIER=3
MAX_CYCLES_PER_MARKET=8
MAX_BUYS_PER_SIDE=10
ENTER_FROM_OPEN_SEC_MIN=3
ENTER_FROM_OPEN_SEC_MAX=230
NORMAL_ENTRY_CUTOFF_SEC_TO_CLOSE=60
COMPLETION_ONLY_CUTOFF_SEC_TO_CLOSE=20
HARD_CANCEL_SEC_TO_CLOSE=10
PARTIAL_COMPLETION_FRACTIONS=0.50,0.75,1
MAX_RESIDUAL_HOLD_SHARES=10
RESIDUAL_UNWIND_SEC_TO_CLOSE=15
SELL_UNWIND_ENABLED=false
DAILY_MAX_LOSS_USDC=50
MARKET_MAX_LOSS_USDC=10
MIN_USDC_BALANCE=10
BOOK_STALE_MS=2000
BALANCE_STALE_MS=5000
RECORDER_ENABLED=false
