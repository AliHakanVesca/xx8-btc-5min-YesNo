NODE_ENV=development
# post-cutover-v2 -> current Polymarket production after V2 migration
# current-prod-v1 -> legacy pre-cutover fallback only
POLY_STACK_MODE=post-cutover-v2
DRY_RUN=true
STATE_STORE=SQLITE
STATE_DB_PATH=data/xuan_state.sqlite
# Leave blank to derive from POLY_STACK_MODE.
USE_CLOB_V2=
LOG_LEVEL=info
# Legacy fallback; runtime now prefers STATE_DB_PATH.
STATE_STORE_PATH=data/runtime/xuan-state.sqlite
BOT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
BOT_PRIVATE_KEY=
POLY_SIGNATURE_TYPE=0
POLY_FUNDER=
# These can be derived with:
# npm run clob:derive -- --write-env
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_RELAYER_API_KEY=
POLY_RELAYER_API_KEY_ADDRESS=
POLY_RELAYER_BASE_URL=https://relayer-v2.polymarket.com
POLY_CHAIN_ID=137
# Working public fallback. Live icin authenticated/private Polygon RPC tercih et.
POLY_RPC_URL=https://polygon-bor-rpc.publicnode.com
# Leave blank to derive from POLY_STACK_MODE.
# Override to https://clob-v2.polymarket.com only when explicitly testing V2 preview pre-cutover.
POLY_CLOB_BASE_URL=
POLY_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLY_DATA_API_BASE_URL=https://data-api.polymarket.com
